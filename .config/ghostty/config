font-family = Iosevka
font-size = 16

theme = Rose Pine
background = 000000
foreground = e0def4
cursor-color = e0def4
selection-invert-fg-bg = true

macos-titlebar-style = hidden
window-padding-x = 8
window-padding-y = 8

shell-integration-features = sudo

keybind = cmd+t=unbind
keybind = cmd+d=unbind
keybind = cmd+n=unbind
keybind = ctrl+tab=text:\x1b[9;5u
